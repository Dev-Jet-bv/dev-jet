---
import Layout from '../layouts/Layout.astro';

const services = [
	{
		icon: "fa-globe",
		title: "Web Development",
		description: "Fast, accessible, and beautifully crafted web applications. From marketing sites to complex platforms — built with modern frameworks that last.",
		tags: ["React", "Astro", "Next.js", "TypeScript"],
	},
	{
		icon: "fa-mobile-screen",
		title: "Mobile Apps",
		description: "Cross-platform mobile experiences that feel truly native. Ship to iOS and Android simultaneously without sacrificing quality.",
		tags: [".NET MAUI", "iOS", "Android"],
	},
	{
		icon: "fa-microchip",
		title: "Custom Solutions",
		description: "Tailored software for unique challenges. APIs, hardware integrations, embedded systems — we thrive on problems that don't have off-the-shelf answers.",
		tags: ["APIs", "IoT", "Hardware", "Audio"],
	},
];

const process = [
	{ step: "01", title: "Discovery", description: "We start by deeply understanding your goals, users, and constraints. No assumptions — just clear alignment on what success looks like." },
	{ step: "02", title: "Design", description: "Clean, intentional interfaces designed for clarity and delight. Every decision is purposeful, with your brand and users at the center." },
	{ step: "03", title: "Build", description: "Performant, maintainable code delivered fast. We ship iteratively so you see real progress early and often." },
	{ step: "04", title: "Launch", description: "We handle deployment, monitoring, and post-launch support — so you can focus on growing what we built together." },
];
---

<Layout title="Dev Jet | Web & Mobile Development">
	<!-- Background -->
	<div class="fixed inset-0 -z-10 bg-gray-50">
		<div class="grid-bg absolute inset-0"></div>
		<div class="orb orb-1"></div>
		<div class="orb orb-2"></div>
		<div class="orb orb-3"></div>
	</div>

	<!-- Sticky Nav -->
	<nav class="fixed top-0 inset-x-0 z-50 border-b border-gray-200 backdrop-blur-xl bg-white/80">
		<div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
			<img src="/logo.png" alt="Dev Jet" class="h-7 object-contain brightness-0 opacity-80" />
			<a href="#contact" class="nav-cta">
				Get in touch <i class="fas fa-arrow-right ml-2 text-xs"></i>
			</a>
		</div>
	</nav>

	<main class="text-gray-900">

		<!-- ── Hero ────────────────────────────────────────────── -->
		<section class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20">
			<div class="reveal">
				<span class="badge mb-8">Software Development Studio</span>
				<h1 class="hero-title mb-6">
					We build<br>
					<span class="gradient-text">digital products</span><br>
					that matter.
				</h1>
				<p class="text-lg md:text-xl text-gray-500 max-w-xl mx-auto mb-12 leading-relaxed">
					High-quality web & mobile experiences crafted with precision,
					performance, and genuine care for the end user.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="#work" class="btn-primary">See our work</a>
					<a href="#contact" class="btn-ghost">Start a project</a>
				</div>
			</div>

			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-gray-400 text-xs tracking-widest uppercase">
				<span>Scroll</span>
				<div class="scroll-line"></div>
			</div>
		</section>

		<!-- ── Services ────────────────────────────────────────── -->
		<section id="services" class="py-28 px-6">
			<div class="max-w-6xl mx-auto">
				<div class="reveal text-center mb-16">
					<span class="badge mb-5">What We Do</span>
					<h2 class="section-title">Full-stack expertise,<br>start to finish.</h2>
					<p class="text-gray-500 text-lg max-w-lg mx-auto mt-5">
						We handle everything from concept to deployment — so you can focus on what matters most to your business.
					</p>
				</div>

				<div class="grid md:grid-cols-3 gap-5">
					{services.map((s, i) => (
						<div class="reveal card group" style={`--delay:${i * 100}ms`}>
							<div class="icon-box mb-6 group-hover:scale-110 group-hover:border-brand/40 transition-all duration-300">
								<i class={`fas ${s.icon} text-brand`}></i>
							</div>
							<h3 class="text-xl font-bold mb-3">{s.title}</h3>
							<p class="text-gray-500 text-sm leading-relaxed mb-6">{s.description}</p>
							<div class="flex flex-wrap gap-2">
								{s.tags.map(tag => (
									<span class="tag">{tag}</span>
								))}
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ── Featured Project ─────────────────────────────────── -->
		<section id="work" class="py-28 px-6">
			<div class="max-w-6xl mx-auto">
				<div class="reveal text-center mb-16">
					<span class="badge mb-5">Featured Project</span>
					<h2 class="section-title">Our latest work.</h2>
				</div>

				<div class="reveal card-featured">
					<div class="flex flex-col lg:flex-row gap-12 items-center">
						<!-- Info -->
						<div class="flex-1">
							<div class="flex items-center gap-4 mb-6">
								<img src="/eggbox/logo.png" alt="Eggbox" class="size-14 object-contain rounded-2xl" />
								<div>
									<h3 class="text-3xl font-black tracking-tight">Eggbox</h3>
									<p class="text-brand text-sm font-semibold mt-0.5">Mobile Application · .NET MAUI</p>
								</div>
							</div>
							<p class="text-gray-600 text-lg leading-relaxed mb-4">
								A companion app for the custom-built Eggbox audio mixer — designed for silent music rehearsals where every musician hears their own personalised mix.
							</p>
							<p class="text-gray-400 text-sm leading-relaxed mb-8">
								Built with .NET MAUI for seamless cross-platform performance on iOS and Android. Features real-time communication with the hardware mixer, an intuitive channel interface, and rock-solid Wi-Fi reliability — even in noisy environments.
							</p>
							<div class="flex flex-wrap gap-2 mb-8">
								{[".NET MAUI", "iOS", "Android", "Real-time Audio"].map(tag => (
									<span class="tag tag-brand">{tag}</span>
								))}
							</div>
							<a href="https://eggbox.be" target="_blank" rel="noopener noreferrer" class="btn-primary inline-flex">
								Visit eggbox.be <i class="fas fa-arrow-up-right-from-square ml-2 text-sm"></i>
							</a>
						</div>

						<!-- App screenshots -->
						<div class="w-full lg:w-96 shrink-0 flex items-center justify-center py-8 lg:py-0">
							<div class="screens-fan">
								<div class="screen screen-left">
									<img src="/eggbox/screens/1.png" alt="Eggbox IN/OUT setup screen" />
								</div>
								<div class="screen screen-center">
									<img src="/eggbox/screens/2.png" alt="Eggbox mixer faders" />
								</div>
								<div class="screen screen-right">
									<img src="/eggbox/screens/3.png" alt="Eggbox all set screen" />
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ── Process ──────────────────────────────────────────── -->
		<section class="py-28 px-6">
			<div class="max-w-6xl mx-auto">
				<div class="reveal text-center mb-16">
					<span class="badge mb-5">How We Work</span>
					<h2 class="section-title">Simple process,<br>outstanding results.</h2>
				</div>

				<div class="grid sm:grid-cols-2 md:grid-cols-4 gap-5">
					{process.map((p, i) => (
						<div class="reveal card process-card" style={`--delay:${i * 80}ms`}>
							<div class="step-number">{p.step}</div>
							<h3 class="text-base font-bold mb-2">{p.title}</h3>
							<p class="text-gray-600 text-sm leading-relaxed">{p.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ── Why Us ────────────────────────────────────────────── -->
		<section class="py-28 px-6 border-y border-gray-200">
			<div class="max-w-6xl mx-auto">
				<div class="flex flex-col lg:flex-row gap-16 items-center">
					<div class="reveal flex-1">
						<span class="badge mb-5">Why Dev Jet</span>
						<h2 class="section-title mb-6">Small team.<br>Big output.</h2>
						<p class="text-gray-600 text-lg leading-relaxed mb-6">
							We're a small, focused studio — which means every project gets our full attention. No handoffs to junior developers, no lost context between teams. Just experienced engineers who care about the work.
						</p>
						<p class="text-gray-500 leading-relaxed">
							We work closely with founders, product teams, and creative agencies to turn complex ideas into polished software. Fast turnaround, transparent communication, and code you can actually maintain long-term.
						</p>
					</div>
					<div class="reveal flex-1 grid grid-cols-2 gap-4">
						{[
							{ icon: "fa-bolt", title: "Fast delivery", desc: "We ship iteratively and keep you in the loop — no month-long silences." },
							{ icon: "fa-code", title: "Clean code", desc: "Maintainable, well-structured code that doesn't become technical debt." },
							{ icon: "fa-comments", title: "Direct comms", desc: "You talk to the people actually building your product. Always." },
							{ icon: "fa-shield-halved", title: "Built to last", desc: "We design for the long term — scalable architecture from day one." },
						].map((item, i) => (
							<div class="card p-5" style={`--delay:${i * 80}ms`}>
								<div class="icon-box mb-4 size-12">
									<i class={`fa-duotone fa-light ${item.icon} text-brand text-base`}></i>
								</div>
								<h4 class="font-bold text-sm mb-2">{item.title}</h4>
								<p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- ── Contact ──────────────────────────────────────────── -->
		<section id="contact" class="py-28 px-6">
			<div class="max-w-6xl mx-auto">
				<div class="reveal text-center mb-16">
					<span class="badge mb-5">Get in Touch</span>
					<h2 class="section-title">Let's build something<br>great together.</h2>
					<p class="text-gray-500 text-lg max-w-lg mx-auto mt-5">
						Have a project in mind? Need support with one of our apps? We'd love to hear from you.
					</p>
				</div>

				<div class="grid md:grid-cols-5 gap-6 max-w-5xl mx-auto items-start">
					<!-- Contact meta cards -->
					<div class="reveal md:col-span-2 space-y-4">
						<div class="card p-6">
							<div class="icon-box mb-4"><i class="fas fa-envelope text-brand"></i></div>
							<p class="text-gray-400 text-xs uppercase tracking-wider mb-1">Email</p>
							<a href="mailto:niels@devjet.be" class="text-brand font-semibold hover:underline text-sm">niels@devjet.be</a>
						</div>
						<div class="card p-6">
							<div class="icon-box mb-4"><i class="fas fa-clock text-brand"></i></div>
							<p class="text-gray-400 text-xs uppercase tracking-wider mb-1">Response time</p>
							<p class="text-sm font-semibold">Within 24 hours</p>
							<p class="text-gray-400 text-xs mt-0.5">Usually much faster</p>
						</div>
					</div>

					<!-- Form -->
					<form
						name="contact"
						method="POST"
						data-netlify="true"
						class="reveal md:col-span-3 card p-8 space-y-5"
					>
						<div class="grid grid-cols-2 gap-5">
							<div>
								<label for="name" class="field-label">Name</label>
								<input type="text" id="name" name="name" required class="field-input" placeholder="Your name" />
							</div>
							<div>
								<label for="email" class="field-label">Email</label>
								<input type="email" id="email" name="email" required class="field-input" placeholder="your@email.com" />
							</div>
						</div>
						<div>
							<label for="app" class="field-label">What's this about?</label>
							<select id="app" name="app" class="field-input appearance-none">
								<option value="eggbox">Eggbox support</option>
								<option value="project">New project inquiry</option>
								<option value="other">Other</option>
							</select>
						</div>
						<div>
							<label for="message" class="field-label">Message</label>
							<textarea id="message" name="message" rows="5" required class="field-input" placeholder="Tell us about your project or question..."></textarea>
						</div>
						<button type="submit" class="btn-primary w-full justify-center">
							Send Message <i class="fas fa-paper-plane ml-2 text-sm"></i>
						</button>
					</form>
				</div>
			</div>
		</section>

		<!-- ── Footer ───────────────────────────────────────────── -->
		<footer class="py-10 px-6 border-t border-gray-200">
			<div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-5">
				<div class="flex items-center gap-4">
					<img src="/logo.png" alt="Dev Jet" class="h-5 object-contain brightness-0 opacity-70" />
					<span class="text-gray-400 text-sm">&copy; {new Date().getFullYear()} Dev Jet. All rights reserved.</span>
				</div>
				<div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1 text-sm text-gray-600">
					<a href="mailto:niels@devjet.be" class="hover:text-brand transition-colors">niels@devjet.be</a>
					<span>·</span>
					<span>BE0744498358</span>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<style>
	/* ── Background ──────────────────────────────────────────── */
	.grid-bg {
		background-image:
			linear-gradient(rgba(0,0,0,0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(0,0,0,0.05) 1px, transparent 1px);
		background-size: 64px 64px;
	}
	.orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(90px);
		animation: drift 10s ease-in-out infinite;
		pointer-events: none;
	}
	.orb-1 {
		width: 500px; height: 500px;
		background: radial-gradient(circle, rgba(154,37,190,0.12), transparent 70%);
		top: -15%; left: -10%;
		animation-duration: 12s;
	}
	.orb-2 {
		width: 380px; height: 380px;
		background: radial-gradient(circle, rgba(154,37,190,0.08), transparent 70%);
		top: 45%; right: -8%;
		animation-delay: -4s;
		animation-duration: 14s;
	}
	.orb-3 {
		width: 300px; height: 300px;
		background: radial-gradient(circle, rgba(154,37,190,0.06), transparent 70%);
		bottom: 5%; left: 25%;
		animation-delay: -8s;
		animation-duration: 16s;
	}
	@keyframes drift {
		0%, 100% { transform: translate(0, 0) scale(1); }
		33%       { transform: translate(20px, -30px) scale(1.04); }
		66%       { transform: translate(-15px, 20px) scale(0.97); }
	}

	/* ── Typography ──────────────────────────────────────────── */
	.hero-title {
		font-size: clamp(3rem, 8vw, 7rem);
		font-weight: 900;
		line-height: 0.95;
		letter-spacing: -0.03em;
	}
	.section-title {
		font-size: clamp(2rem, 4.5vw, 3.25rem);
		font-weight: 900;
		line-height: 1.08;
		letter-spacing: -0.025em;
	}

	/* Animated shimmer gradient text */
	.gradient-text {
		background: linear-gradient(120deg, #f43f8b 0%, #f59e0b 50%, #f43f8b 100%);
		background-size: 200% auto;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: shimmer 5s linear infinite;
	}
	@keyframes shimmer {
		0%   { background-position: 0% center; }
		100% { background-position: 200% center; }
	}

	/* ── Badge ───────────────────────────────────────────────── */
	.badge {
		display: inline-block;
		padding: 0.3rem 1rem;
		background: rgba(154,37,190,0.08);
		border: 1px solid rgba(154,37,190,0.2);
		color: #9a25be;
		font-size: 0.7rem;
		font-weight: 700;
		border-radius: 9999px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	/* ── Nav ─────────────────────────────────────────────────── */
	.nav-cta {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1.25rem;
		border: 1px solid rgba(154,37,190,0.35);
		color: #9a25be;
		font-size: 0.8125rem;
		font-weight: 600;
		border-radius: 9999px;
		transition: all 0.2s;
	}
	.nav-cta:hover {
		background: #9a25be;
		color: white;
	}

	/* ── Cards ───────────────────────────────────────────────── */
	.card {
		background: rgba(0,0,0,0.02);
		border: 1px solid rgba(0,0,0,0.07);
		border-radius: 1.5rem;
		padding: 2rem;
		transition: border-color 0.3s ease, transform 0.3s ease, background 0.3s ease;
	}
	.card:hover {
		border-color: rgba(154,37,190,0.2);
		background: rgba(154,37,190,0.04);
		transform: translateY(-3px);
	}

	.card-featured {
		background: rgba(0,0,0,0.02);
		border: 1px solid rgba(0,0,0,0.07);
		border-radius: 2rem;
		padding: 2.5rem 3rem;
		position: relative;
		overflow: hidden;
	}
	.card-featured::before {
		content: '';
		position: absolute;
		top: 0; left: 0; right: 0;
		height: 1px;
		background: linear-gradient(90deg, transparent 10%, rgba(154,37,190,0.5) 50%, transparent 90%);
	}

	.screens-fan {
		position: relative;
		width: 320px;
		height: 380px;
	}
	.screen {
		position: absolute;
		border-radius: 10px;
		overflow: hidden;
		box-shadow: 0 24px 60px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.07);
	}
	.screen img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.screen-left {
		width: 118px;
		height: 256px;
		top: 62px;
		left: 16px;
		transform: rotate(-9deg);
		z-index: 1;
		opacity: 0.55;
		filter: brightness(0.85);
	}
	.screen-center {
		width: 152px;
		height: 328px;
		top: 26px;
		left: 50%;
		transform: translateX(-50%);
		z-index: 3;
		animation: floatPhone 4.5s ease-in-out infinite;
	}
	.screen-right {
		width: 118px;
		height: 256px;
		top: 62px;
		right: 16px;
		transform: rotate(9deg);
		z-index: 1;
		opacity: 0.55;
		filter: brightness(0.85);
	}
	@keyframes floatPhone {
		0%, 100% { transform: translateX(-50%) translateY(0px); }
		50%       { transform: translateX(-50%) translateY(-10px); }
	}

	.process-card {
		text-align: left;
		position: relative;
	}
	.step-number {
		font-size: 3.5rem;
		font-weight: 900;
		color: rgba(0,0,0,0.1);
		line-height: 1;
		margin-bottom: 0.75rem;
		letter-spacing: -0.04em;
	}

	/* ── Icon box ────────────────────────────────────────────── */
	.icon-box {
		width: 2.75rem;
		height: 2.75rem;
		background: rgba(154,37,190,0.08);
		border: 1px solid rgba(154,37,190,0.18);
		border-radius: 0.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s;
	}

	/* ── Tags ────────────────────────────────────────────────── */
	.tag {
		font-size: 0.7rem;
		padding: 0.25rem 0.625rem;
		border-radius: 9999px;
		background: rgba(0,0,0,0.05);
		border: 1px solid rgba(0,0,0,0.08);
		color: rgba(0,0,0,0.45);
	}
	.tag-brand {
		background: rgba(154,37,190,0.08);
		border-color: rgba(154,37,190,0.2);
		color: #9a25be;
	}

	/* ── Buttons ─────────────────────────────────────────────── */
	.btn-primary {
		display: inline-flex;
		align-items: center;
		padding: 0.875rem 1.75rem;
		background: #9a25be;
		color: white;
		font-weight: 700;
		font-size: 0.875rem;
		border-radius: 0.875rem;
		transition: all 0.2s;
		cursor: pointer;
		box-shadow: 0 6px 20px rgba(154,37,190,0.25);
	}
	.btn-primary:hover {
		background: #8020a8;
		transform: translateY(-2px);
		box-shadow: 0 10px 30px rgba(154,37,190,0.35);
	}
	.btn-primary:active { transform: scale(0.98); }

	.btn-ghost {
		display: inline-flex;
		align-items: center;
		padding: 0.875rem 1.75rem;
		background: rgba(0,0,0,0.04);
		border: 1px solid rgba(0,0,0,0.1);
		color: rgba(0,0,0,0.65);
		font-weight: 700;
		font-size: 0.875rem;
		border-radius: 0.875rem;
		transition: all 0.2s;
	}
	.btn-ghost:hover {
		background: rgba(0,0,0,0.08);
		border-color: rgba(0,0,0,0.15);
		color: black;
		transform: translateY(-2px);
	}

	/* ── Form ────────────────────────────────────────────────── */
	.field-label {
		display: block;
		font-size: 0.75rem;
		font-weight: 600;
		color: rgb(0 0 0 / 0.5);
		margin-bottom: 0.4rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.field-input {
		width: 100%;
		padding: 0.75rem 1rem;
		background: rgba(0,0,0,0.03);
		border: 1px solid rgba(0,0,0,0.1);
		border-radius: 0.75rem;
		color: #111;
		font-size: 0.875rem;
		outline: none;
		transition: all 0.2s;
		font-family: inherit;
	}
	.field-input::placeholder { color: rgba(0,0,0,0.28); }
	.field-input:focus {
		border-color: rgba(154,37,190,0.5);
		background: rgba(154,37,190,0.03);
		box-shadow: 0 0 0 3px rgba(154,37,190,0.08);
	}
	.field-input option {
		background: white;
		color: #111;
	}

	/* ── Scroll indicator ────────────────────────────────────── */
	.scroll-line {
		width: 1px;
		height: 40px;
		background: linear-gradient(to bottom, rgba(0,0,0,0.25), transparent);
		animation: scrollPulse 2.5s ease-in-out infinite;
	}
	@keyframes scrollPulse {
		0%, 100% { opacity: 1; transform: scaleY(1) translateY(0); }
		50%       { opacity: 0.2; transform: scaleY(0.5) translateY(6px); }
	}

	/* ── Reveal animation ────────────────────────────────────── */
	.reveal {
		opacity: 0;
		transform: translateY(28px);
		transition: opacity 0.75s ease, transform 0.75s ease;
		transition-delay: var(--delay, 0ms);
	}
	.reveal.in-view {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.classList.add('in-view');
				}
			});
		},
		{ threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
	);

	document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
