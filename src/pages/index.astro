---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dev Jet | Web & Mobile Development">
	<main class="max-w-4xl mx-auto px-6 py-12 md:py-20">
		<!-- Header / Hero Section -->
		<header class="flex flex-col items-center text-center mb-16 md:mb-24">
			
			<span class="inline-block px-3 py-1 bg-brand/10 text-brand text-sm font-semibold rounded-full mb-4 border border-brand/20">
						Software Development Studio
					</span>
			<img src="/logo.png" alt="Dev Jet Logo" class="w-64 object-contain" />
			<p class="text-xl md:text-4xl mt-8 font-bold text-slate-600 max-w-2xl">
				Crafting high-quality, performant web & mobile experiences.
			</p>
		</header>

		<!-- Featured Project: Eggbox -->
		<section class="bg-white border border-slate-200 rounded-3xl p-8 md:p-12 mb-16 shadow-sm">
			<div class="flex flex-col md:flex-row gap-8 items-center">
				<div class="flex-1 text-center md:text-left">
					<span class="inline-block px-3 py-1 bg-brand/10 text-brand text-sm font-semibold rounded-full mb-4 border border-brand/20">
						Featured App
					</span>
					<div class="flex items-center gap-4 mb-4">
						<img src="/eggbox/logo.png" alt="Eggbox Logo" class="size-9 object-contain" />
						<h2 class="text-3xl font-bold text-slate-700 font-display">Eggbox</h2>
					</div>
					<p class="text-lg text-slate-600 mb-6">
						Our latest IOS and Android application built with .NET MAUI. The app is used to communicate with our custom Eggbox audio mixer for silent music rehearsals.
					</p>
					<a 
						href="https://eggbox.be" 
						target="_blank" 
						rel="noopener noreferrer"
						class="inline-flex items-center py-3 px-6 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-xl transition-colors shadow-lg shadow-slate-200 active:scale-[0.98] cursor-pointer"
					>
						Read more <i class="fas fa-chevron-right ml-2 text-sm"></i>
					</a>
				</div>
				<div class="w-full md:w-1/3 aspect-square bg-slate-50 rounded-2xl flex items-center justify-center border border-dashed border-slate-300">
					<span class="text-slate-400 font-medium text-center">Coming soon for<br> Android & iOS</span>
				</div>
			</div>
		</section>

		<!-- Support Section -->
		<section id="support" class="mb-16 md:mb-24">
			<div class="text-center mb-12">
				<h2 class="text-3xl font-bold mb-4 text-slate-900 font-display">Support & Contact</h2>
				<p class="text-lg text-slate-600">
					Need help with one of our apps? Or just want to say hello?
				</p>
			</div>

			<form 
				name="contact" 
				method="POST" 
				data-netlify="true" 
				class="bg-white border border-slate-200 rounded-3xl p-8 md:p-12 shadow-sm max-w-2xl mx-auto space-y-6"
			>
				<div>
					<label for="name" class="block text-sm font-medium text-slate-700 mb-1">Name</label>
					<input 
						type="text" 
						id="name" 
						name="name" 
						required 
						class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-brand focus:border-brand transition-all outline-none"
						placeholder="Your Name"
					/>
				</div>
				<div>
					<label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
					<input 
						type="email" 
						id="email" 
						name="email" 
						required 
						class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-brand focus:border-brand transition-all outline-none"
						placeholder="john@company.com"
					/>
				</div>
				<div>
					<label for="app" class="block text-sm font-medium text-slate-700 mb-1">App (optional)</label>
					<select 
						id="app" 
						name="app" 
						class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-brand focus:border-brand transition-all outline-none appearance-none"
					>
						<option value="eggbox">Eggbox</option>
						<option value="other">Other Inquiry</option>
					</select>
				</div>
				<div>
					<label for="message" class="block text-sm font-medium text-slate-700 mb-1">Message</label>
					<textarea 
						id="message" 
						name="message" 
						rows="4" 
						required 
						class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-brand focus:border-brand transition-all outline-none"
						placeholder="How can we help you?"
					></textarea>
				</div>
				<button 
					type="submit" 
					class="w-full py-4 px-6 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-xl transition-colors shadow-lg shadow-slate-200 active:scale-[0.98] cursor-pointer"
				>
					Send Message <i class="fas fa-paper-plane ml-2 text-sm"></i>
				</button>
			</form>
		</section>

		<!-- Footer -->
		<footer class="text-center border-t border-slate-200 pt-12">
			<p class="text-slate-600 mb-4">
				&copy; {new Date().getFullYear()} Dev Jet. All rights reserved.
			</p>
			<p class="font-medium text-slate-900">
				<a href="mailto:niels@devjet.be" class="hover:text-brand transition-colors">niels@devjet.be</a>
			</p>
		</footer>
	</main>
</Layout>
