---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Dev Jet - Web & Mobile Development. Home of Eggbox." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/icon.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&display=swap" rel="stylesheet">
		<script src="https://kit.fontawesome.com/03fca1712c.js" crossorigin="anonymous"></script>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 selection:bg-blue-100 selection:text-blue-900">
		<slot />
	</body>
</html>
